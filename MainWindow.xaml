<ui:FluentWindow x:Class="ClipboardHistory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:ClipboardHistory"
        mc:Ignorable="d"
        Title="Clipboard History" 
        Height="650" Width="450"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </ui:FluentWindow.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Portapapeles"
                     ShowMinimize="False"
                     ShowMaximize="False"
                     ShowClose="True"/>

        <!-- Search Bar -->
        <Grid Grid.Row="1" Margin="16,4,16,8">
            <ui:TextBox x:Name="SearchBox"
                        PlaceholderText="Buscar en el historial..."
                        Icon="{ui:SymbolIcon Search24}"
                        TextChanged="SearchBox_TextChanged"/>
        </Grid>

        <!-- Tabs -->
        <TabControl x:Name="MainTabControl" Grid.Row="2" 
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="8,0,8,8">

            <!-- ==================== Tab: Texto ==================== -->
            <TabItem Header="📝 Texto" Background="Transparent">
                <ScrollViewer x:Name="TextScrollViewer" VerticalScrollBarVisibility="Auto" 
                              Background="Transparent"
                              Margin="0,8,0,0">
                    <ItemsControl x:Name="ClipboardListView" Background="Transparent">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="8"
                                        Margin="4,3"
                                        Padding="14,10"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="CardClick_Handler"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Content}" 
                                                       MaxHeight="42" 
                                                       TextWrapping="Wrap" 
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:dd/MM  HH:mm:ss}'}" 
                                                       FontSize="11" 
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" 
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:Button Appearance="Secondary"
                                                       Icon="{ui:SymbolIcon Pin24}"
                                                       Click="PinButton_Click"
                                                       Tag="{Binding}"
                                                       ToolTip="Anclar"
                                                       Margin="0,0,4,0"/>
                                            <ui:Button Appearance="Secondary"
                                                       Icon="{ui:SymbolIcon Delete24}"
                                                       Click="DeleteButton_Click"
                                                       Tag="{Binding}"
                                                       ToolTip="Eliminar"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== Tab: Imágenes ==================== -->
            <TabItem Header="🖼️ Imágenes" Background="Transparent">
                <Grid Background="Transparent">
                    <!-- Empty state (shown when no images) -->
                    <StackPanel x:Name="ImagesEmptyState"
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <ui:SymbolIcon Symbol="Image24" FontSize="48"
                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                      Margin="0,0,0,12"/>
                        <TextBlock Text="Sin imágenes aún" 
                                   FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Copia una imagen al portapapeles para verla aquí" 
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Image Grid -->
                    <ScrollViewer x:Name="ImageScrollViewer" VerticalScrollBarVisibility="Auto" 
                                  Background="Transparent"
                                  Margin="0,8,0,0">
                        <ItemsControl x:Name="ImageListView" Background="Transparent">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"
                                               HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Image Card -->
                                    <Border Width="190" 
                                            Margin="4,4"
                                            CornerRadius="10"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="ImageCardClick_Handler"
                                            Tag="{Binding}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="140"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Thumbnail with rounded top corners -->
                                            <Border Grid.Row="0" 
                                                    CornerRadius="9,9,0,0"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                <Image Source="{Binding Thumbnail}" 
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Pin indicator overlay (top-left) -->
                                            <Border Grid.Row="0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="6,6"
                                                    Padding="4,2"
                                                    CornerRadius="4"
                                                    Background="#AA000000"
                                                    Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}">
                                                <ui:SymbolIcon Symbol="Pin24" FontSize="12" Foreground="#FFB347"/>
                                            </Border>

                                            <!-- Metadata row -->
                                            <StackPanel Grid.Row="1" Margin="10,8,10,2">
                                                <TextBlock Text="{Binding ResolutionText}" 
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding FileSizeText}" 
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                    <TextBlock Text="  •  " FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" 
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Action buttons -->
                                            <StackPanel Grid.Row="2" 
                                                        Orientation="Horizontal" 
                                                        HorizontalAlignment="Right"
                                                        Margin="4,2,4,6">
                                                <ui:Button Appearance="Secondary"
                                                           Icon="{ui:SymbolIcon Copy24}"
                                                           Click="ImageCopyButton_Click"
                                                           Tag="{Binding}"
                                                           ToolTip="Copiar imagen"
                                                           Padding="6,4"
                                                           Margin="0,0,2,0"/>
                                                <ui:Button Appearance="Secondary"
                                                           Icon="{ui:SymbolIcon Pin24}"
                                                           Click="ImagePinButton_Click"
                                                           Tag="{Binding}"
                                                           ToolTip="Anclar"
                                                           Padding="6,4"
                                                           Margin="0,0,2,0"/>
                                                <ui:Button Appearance="Secondary"
                                                           Icon="{ui:SymbolIcon Delete24}"
                                                           Click="ImageDeleteButton_Click"
                                                           Tag="{Binding}"
                                                           ToolTip="Eliminar"
                                                           Padding="6,4"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ==================== Tab: Fijados ==================== -->
            <TabItem Header="📌 Fijados" Background="Transparent">
                <ScrollViewer x:Name="PinnedScrollViewer" VerticalScrollBarVisibility="Auto" 
                              Background="Transparent"
                              Margin="0,8,0,0">
                    <ItemsControl x:Name="PinnedListView" Background="Transparent">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="8"
                                        Margin="4,3"
                                        Padding="14,10"
                                        BorderBrush="{DynamicResource SystemFillColorAttentionBrush}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="CardClick_Handler"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ui:SymbolIcon Grid.Column="0" 
                                                       Symbol="Pin24" 
                                                       Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Content}" 
                                                       MaxHeight="42" 
                                                       TextWrapping="Wrap" 
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:dd/MM  HH:mm:ss}'}" 
                                                       FontSize="11" 
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" 
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <ui:Button Grid.Column="2"
                                                   Appearance="Secondary"
                                                   Icon="{ui:SymbolIcon PinOff24}"
                                                   Click="PinButton_Click"
                                                   Tag="{Binding}"
                                                   ToolTip="Desanclar"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>

</ui:FluentWindow>
